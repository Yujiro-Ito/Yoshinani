{
  "version": 2,
  "cmakeMinimumRequired": { "major": 3, "minor": 20, "patch": 0 },
  "configurePresets": [
    {
      "name": "ninja-debug",
      "displayName": "Ninja Debug (x64)",
      "description": "VS Build Tools の MSVC 環境(vcvars64)を読み込んだシェルで使う。scripts/build.ps1 が自動でこれ相当を実行する。",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ninja-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "ninja-release",
      "displayName": "Ninja Release (x64)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ninja-release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    }
  ]
}

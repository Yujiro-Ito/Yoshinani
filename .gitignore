[Dd]ebug/
[Rr]elease/
[Dd]ebugPublic/
[Rr]eleases/
[Xx]64/
[Xx]86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
bld/

# Visual Studio キャッシュ / ユーザー設定
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
*.VC.db
*.VC.VC.opendb
*.opensdf
*.sdf

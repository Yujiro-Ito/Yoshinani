CMakeUserPresets.json
CTestTestfile.cmake
compile_commands.json
_deps/

# ---- パッケージマネージャ (vcpkg 等) ----
vcpkg_installed/

# ============================================================
#  LLM モデル / 重み（大容量バイナリ。Git に載せない）
#  zenz (GGUF) / llama.cpp の weights は各自ダウンロードする
# ============================================================
*.gguf
*.ggml
*.bin
*.safetensors
*.pt
*.pth
models/
weights/

# ---- vendor した llama.cpp のビルド産物のみ無視 ----
**/llama.cpp/build/

# ---- IDE / エディタ ----
.idea/
*.swp
*~

# ---- OS 生成ファイル ----
Thumbs.db
ehthumbs.db
